ngx_addon_name=ngx_http_openhttpa_module
if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name=ngx_http_openhttpa_module
    ngx_module_srcs="$ngx_addon_dir/src/lib.rs"
    ngx_module_libs="-L$ngx_addon_dir/../../target/release -lopenhttpa_nginx"
    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_openhttpa_module"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $ngx_addon_dir/src/lib.rs"
fi
