{
  "_comment": "SA-05 minimal seccomp allow-list for the OpenHTTPA backend (static Rust binary serving HTTP/2 on a non-privileged port). Derived from the Docker default seccomp profile then restricted to only the syscalls actually observed in a Rust async-HTTP server. Any syscall not listed here will be blocked with EPERM. Review and update if new syscall patterns are added (e.g., io_uring, eBPF).",
  "defaultAction": "SCMP_ACT_ERRNO",
  "architectures": ["SCMP_ARCH_X86_64", "SCMP_ARCH_AARCH64"],
  "syscalls": [
    {
      "_comment": "Memory management",
      "names": [
        "brk",
        "mmap",
        "mmap2",
        "munmap",
        "mprotect",
        "mremap",
        "madvise",
        "mincore",
        "msync"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "File I/O — needed for TLS cert loading, FileNonceSequence, and logging",
      "names": [
        "read",
        "write",
        "pread64",
        "pwrite64",
        "readv",
        "writev",
        "open",
        "openat",
        "close",
        "creat",
        "unlink",
        "unlinkat",
        "rename",
        "renameat",
        "renameat2",
        "stat",
        "fstat",
        "lstat",
        "fstatat",
        "newfstatat",
        "stat64",
        "fstat64",
        "lstat64",
        "statx",
        "openat2",
        "close_range",
        "lseek",
        "fcntl",
        "statfs",
        "fstatfs",
        "faccessat",
        "faccessat2",
        "readlink",
        "readlinkat",
        "fsopen",
        "fsmount",
        "fsconfig",
        "fspick",
        "move_mount",
        "open_tree",
        "dup",
        "dup2",
        "dup3",
        "sync",
        "fsync",
        "fdatasync",
        "ftruncate",
        "truncate"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Directory traversal — needed for config file loading",
      "names": ["getdents", "getdents64", "getcwd", "chdir"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Network — TCP server (accept connections, read/write data)",
      "names": [
        "socket",
        "bind",
        "listen",
        "accept",
        "accept4",
        "connect",
        "sendto",
        "sendmsg",
        "recvfrom",
        "recvmsg",
        "sendfile",
        "shutdown",
        "setsockopt",
        "getsockopt",
        "getsockname",
        "getpeername",
        "socketpair",
        "recv",
        "send",
        "poll",
        "epoll_create",
        "epoll_create1",
        "epoll_ctl",
        "epoll_wait",
        "epoll_pwait",
        "select",
        "pselect6",
        "ppoll",
        "epoll_pwait2",
        "recvmmsg",
        "sendmmsg"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Threading and synchronization — required by Tokio async runtime",
      "names": [
        "futex",
        "futex_time64",
        "futex_waitv",
        "clone",
        "clone3",
        "nanosleep",
        "clock_nanosleep",
        "clock_nanosleep_time64",
        "sched_yield",
        "sched_getaffinity",
        "sched_setaffinity",
        "tgkill",
        "tkill",
        "kill",
        "sigaltstack",
        "rt_sigaction",
        "rt_sigprocmask",
        "rt_sigreturn",
        "rt_sigtimedwait",
        "rt_tgsigqueueinfo",
        "pause"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Time — monotonic clock for replay guard and session TTL",
      "names": [
        "clock_gettime",
        "clock_gettime64",
        "clock_getres",
        "gettimeofday",
        "time",
        "adjtimex",
        "clock_adjtime"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Process identity — needed for logging and PID files",
      "names": [
        "getpid",
        "getppid",
        "gettid",
        "getuid",
        "geteuid",
        "getgid",
        "getegid",
        "getgroups",
        "getrusage"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Random number generation — required by ring/aws-lc-rs for key generation and HKDF",
      "names": ["getrandom"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Process control — Tokio worker threads, init signal handling, and health checks. NOTE: execve/execveat are REQUIRED for /sbin/docker-init (init: true) and Docker HEALTHCHECK. While typically restricted in static binaries, we allow them here to support container lifecycle management. Risk is mitigated by using a distroless base (no shell), read-only filesystem, non-root user, and the no-new-privileges:true flag (SA-05/BLOCKER-02 remediation).",
      "names": [
        "execve",
        "execveat",
        "exit",
        "exit_group",
        "setpgid",
        "getpgid",
        "setsid",
        "getsid",
        "wait4",
        "waitid",
        "prctl",
        "arch_prctl",
        "set_robust_list",
        "get_robust_list",
        "set_tid_address",
        "umask",
        "capget",
        "capset",
        "restart_syscall"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Memory-mapped files and huge pages — used by LLVM/ring for performance",
      "names": ["memfd_create", "fallocate"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Pipe/IPC — used by Tokio for internal signalling (e.g. tokio::sync::oneshot)",
      "names": [
        "pipe",
        "pipe2",
        "eventfd",
        "eventfd2",
        "timerfd_create",
        "timerfd_settime",
        "timerfd_gettime",
        "signalfd",
        "signalfd4"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "Resource limits — set by init process or container runtime",
      "names": ["getrlimit", "setrlimit", "prlimit64"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "ioctl — required for terminal detection (isatty) and socket operations",
      "names": ["ioctl"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "sysinfo — sometimes read by Rust std for CPU count detection",
      "names": ["sysinfo", "uname"],
      "action": "SCMP_ACT_ALLOW"
    }
  ]
}
