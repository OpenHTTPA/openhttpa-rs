{
  "name": "@openhttpa/core",
  "version": "0.1.1",
  "description": "OpenHTTPA Node.js bindings",
  "main": "index.js",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:mock": "napi build --platform --release --features mock",
    "test": "OPENHTTPA_TEE_PROVIDER=mock node test/index.mjs"
  },
  "napi": {
    "binaryName": "openhttpa",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "license": "Apache-2.0 OR MIT",
  "author": "The OpenHTTPA Foundation (openhttpa.org) <info@openhttpa.org>",
  "homepage": "https://openhttpa.org",
  "devDependencies": {
    "@napi-rs/cli": "^3"
  }
}
