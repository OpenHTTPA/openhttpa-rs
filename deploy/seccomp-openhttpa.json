      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment": "TEE device ioctls — required for quote generation/verification",
      "names": ["ioctl"],
      "action": "SCMP_ACT_ALLOW",
      "args": []
    }
  ],
  "_blocked_syscalls_rationale": {
    "ptrace": "Prevents in-process memory inspection of cryptographic buffers",
    "process_vm_readv": "Prevents cross-process memory reads of session keys",
    "process_vm_writev": "Prevents cross-process memory writes",
    "perf_event_open": "Side-channel oracle — timing/cache attacks on crypto operations",
    "io_uring_enter": "Large attack surface; not required by Tokio epoll backend",
    "io_uring_register": "Large attack surface; not required by Tokio epoll backend",
    "io_uring_setup": "Large attack surface; not required by Tokio epoll backend",
    "mount": "Container escape prevention",
    "umount2": "Container escape prevention",
    "pivot_root": "Container escape prevention",
    "unshare": "Namespace manipulation prevention",
    "setns": "Namespace manipulation prevention",
    "keyctl": "Kernel key management — not used; reduces attack surface",
    "bpf": "eBPF programs could exfiltrate crypto state"
  }
